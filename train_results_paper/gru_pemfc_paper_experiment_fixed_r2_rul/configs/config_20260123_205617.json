{
    "data_path": "processed_results/FC1/",
    "data_file_pattern": "*_processed_*.npz",
    "data_file_suffix": "_processed",
    "target_feature": "stack_voltage",
    "sequence_length": 80,
    "selected_features": [
        "iTnH2 (°C)",
        "air_outlet_flow",
        "coolant_flow",
        "current",
        "current_density"
    ],
    "missing_value_method": "linear",
    "outlier_method": "3sigma",
    "outlier_sigma": 3.0,
    "wavelet_method": "sym8",
    "wavelet_level": 4,
    "wavelet_threshold_percentile": 70,
    "enable_wavelet": false,
    "train_ratio": 0.8,
    "val_ratio": 0.1,
    "test_ratio": 0.1,
    "forecast_steps": 200,
    "forecast_horizon": 2200.0,
    "forecast_max_steps": 200000,
    "fixed_dt": 0.0084,
    "gru_hidden_size": 256,
    "gru_num_layers": 2,
    "dropout_rate": 0.1,
    "bidirectional": false,
    "fc_hidden_sizes": [
        32,
        16
    ],
    "batch_size": 32,
    "epochs": 45,
    "learning_rate": 0.0006,
    "weight_decay": 0.001,
    "patience": 30,
    "lr_decay_factor": 0.7,
    "lr_patience": 5,
    "grad_clip": 0.5,
    "slope_loss_weight": 0.2,
    "variance_loss_weight": 0.45,
    "apply_fc1_bias_correction": true,
    "fc1_bias_correction": 0.0138,
    "rul_prediction_scale": 0.995,
    "soh_threshold": 0.96,
    "v_initial_window": 100,
    "cv_threshold": 0.01,
    "denoising_method": "wavelet",
    "device": "cuda",
    "save_dir": "train_results_paper",
    "experiment_name": "gru_pemfc_paper_experiment_fixed_r2_rul"
}